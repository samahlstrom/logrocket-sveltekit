{
  "name": "logrocket-sveltekit",
  "version": "0.1.0",
  "description": "LogRocket plugin for SvelteKit — error handling, navigation tracking, and state logging",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "logrocket",
    "sveltekit",
    "svelte",
    "svelte5",
    "runes",
    "session-replay",
    "error-tracking"
  ],
  "license": "MIT",
  "peerDependencies": {
    "logrocket": ">=8.0.0",
    "@sveltejs/kit": ">=2.0.0",
    "svelte": ">=5.0.0"
  },
  "devDependencies": {
    "logrocket": "^8.1.3",
    "@sveltejs/kit": "^2.16.0",
    "svelte": "^5.0.0",
    "typescript": "^5.7.0"
  }
}
